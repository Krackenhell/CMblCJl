# Основная проверка заданий и понимания работает локально. Облачный голосовой режим необязателен.
OPENAI_API_KEY=
# Браузер не получает ключ: Meaning создаёт WebRTC-сессию на серверной стороне.
LOCAL_LLM_URL=http://127.0.0.1:8080
LOCAL_LLM_FAST_URL=http://127.0.0.1:8081
LOCAL_LLM_MODEL=Qwen2.5-7B-Instruct-Q4_K_M
LOCAL_LLM_MODEL_PATH=models/qwen2.5-7b-instruct-q4_k_m.gguf
LOCAL_LLM_FAST_MODEL=Qwen2.5-3B-Instruct-Q4_K_M
LOCAL_LLM_FAST_MODEL_PATH=models/qwen2.5-3b-instruct-q4_k_m.gguf
# 0 — быстрый интерактивный режим (3B); 1 — углублённая проверка 7B на мощном ПК.
LOCAL_LLM_QUALITY_MODE=0
LOCAL_LLM_USE_VULKAN=0
LOCAL_LLM_GPU_LAYERS=18
LOCAL_LLM_SERVER_PATH=tools/llama/llama-server.exe
MEANING_DB_PATH=meaning_trainer.db
